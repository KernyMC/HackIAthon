# Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini / Vertex AI
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768

# AlloyDB
ALLOYDB_HOST=10.x.x.x
ALLOYDB_PORT=5432
ALLOYDB_DATABASE=fraudia
ALLOYDB_USER=app_user
ALLOYDB_PASSWORD=change-me
ALLOYDB_ADMIN_DATABASE=postgres
ALLOYDB_ADMIN_USER=postgres
ALLOYDB_ADMIN_PASSWORD=change-me

# App
APP_ENV=local
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Optional GCS
GCS_BUCKET=fraudia-hackathon-your-project-id
